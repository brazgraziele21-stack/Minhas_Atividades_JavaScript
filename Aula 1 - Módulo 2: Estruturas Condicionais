<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Módulo 2: Estruturas Condicionais</title>
</head>
<body>
<script>
// Exercício 9: Maior entre três números
const n1 = Number(prompt("Digite o primeiro número:"));
const n2 = Number(prompt("Digite o segundo número:"));
const n3 = Number(prompt("Digite o terceiro número:"));

if (n1 === n2 && n2 === n3) {
  alert("Todos os números são iguais.");
} else if (n1 >= n2 && n1 >= n3) {
  alert(`O maior número é ${n1}`);
} else if (n2 >= n1 && n2 >= n3) {
  alert(`O maior número é ${n2}`);
} else {
  alert(`O maior número é ${n3}`);
}


// Exercício 10: Ano bissexto
const ano = Number(prompt("Digite um ano:"));
const bissexto = (ano % 4 === 0 && ano % 100 !== 0) || ano % 400 === 0;
alert(bissexto ? `${ano} é bissexto.` : `${ano} não é bissexto.`);


// Exercício 11: Classificação por conceito
const nota = Number(prompt("Digite uma nota de 0 a 10:"));
let conceito;

switch (true) {
  case nota >= 9: conceito = "A"; break;
  case nota >= 7: conceito = "B"; break;
  case nota >= 5: conceito = "C"; break;
  case nota >= 3: conceito = "D"; break;
  case nota >= 1: conceito = "E"; break;
  default: conceito = "F";
}

alert(`Sua nota (${nota}) corresponde ao conceito: ${conceito}`);


// Exercício 12: Categoria de IMC
const peso = Number(prompt("Digite seu peso (kg):"));
const altura = Number(prompt("Digite sua altura (m):"));
const imc = peso / Math.pow(altura, 2);
let categoria;

if (imc < 18.5) categoria = "abaixo do peso";
else if (imc < 25) categoria = "peso normal";
else if (imc < 30) categoria = "sobrepeso";
else categoria = "obeso";

alert(`Seu IMC é ${imc.toFixed(2)} (${categoria})`);


// Exercício 13: Dia útil vs. fim de semana
const dia = Number(prompt("Digite um número de 1 (domingo) a 7 (sábado):"));

if (dia < 1 || dia > 7) {
  alert("Número inválido! Digite um valor entre 1 e 7.");
} else {
  let nomeDia;
  switch (dia) {
    case 1: nomeDia = "Domingo"; break;
    case 2: nomeDia = "Segunda-feira"; break;
    case 3: nomeDia = "Terça-feira"; break;
    case 4: nomeDia = "Quarta-feira"; break;
    case 5: nomeDia = "Quinta-feira"; break;
    case 6: nomeDia = "Sexta-feira"; break;
    case 7: nomeDia = "Sábado"; break;
    default: nomeDia = "Desconhecido";
  }

  const tipo = dia === 1 || dia === 7 ? "Fim de semana" : "Dia útil";
  alert(`${nomeDia} é um(a) ${tipo}.`);
}


// Exercício 14: Menu de áreas geométricas
const opcao = Number(prompt("Escolha uma opção:\n1 - Quadrado\n2 - Triângulo\n3 - Círculo"));
let area;

switch (opcao) {
  case 1: {
    const lado = Number(prompt("Digite o lado do quadrado:"));
    area = lado * lado;
    break;
  }
  case 2: {
    const base = Number(prompt("Digite a base do triângulo:"));
    const alturaTriangulo = Number(prompt("Digite a altura do triângulo:"));
    area = (base * alturaTriangulo) / 2;
    break;
  }
  case 3: {
    const raio = Number(prompt("Digite o raio do círculo:"));
    area = Math.PI * raio ** 2;
    break;
  }
  default:
    area = null;
}

if (area !== null) {
  alert(`A área calculada é ${area.toFixed(2)}`);
} else {
  alert("Opção inválida.");
}


// Exercício 15: Verificação de múltiplos
const numA = Number(prompt("Digite o primeiro número:"));
const numB = Number(prompt("Digite o segundo número:"));
const mensagem = numA % numB === 0
  ? `${numA} é múltiplo de ${numB}.`
  : `${numA} não é múltiplo de ${numB}.`;
alert(mensagem);


// Exercício 16: Sistema de login simples
const USUARIO_CORRETO = "admin";
const SENHA_CORRETA = "1234";
const usuario = prompt("Digite o usuário:");
const senha = prompt("Digite a senha:");

if (usuario.toLowerCase() === USUARIO_CORRETO && senha === SENHA_CORRETA) {
  alert("Login realizado com sucesso!");
} else {
  alert("Usuário ou senha incorretos.");
}
</script>
</body>
</html>
