<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aula 3 - Exercício 6</title>
  </head>
  <body>
    <div id="quiz"></div>

    <button id="destacar">Destacar primeira</button>

    <script>
      const quiz = document.querySelector("#quiz");
const btnDestacar = document.querySelector("#destacar");

const alternativas = ["A", "B", "C"];

for (let i = 0; i < alternativas.length; i++) {
  const botao = document.createElement("button");
  botao.textContent = alternativas[i];

  botao.addEventListener("click", function () {
    botao.classList.toggle("selecionada");
  });

  quiz.appendChild(botao);
}

btnDestacar.addEventListener("click", function () {
  const selecionada = quiz.querySelector(".selecionada");

  if (selecionada) {
    quiz.insertBefore(selecionada, quiz.firstChild);
  }
});
    </script>
  </body>
</html>
