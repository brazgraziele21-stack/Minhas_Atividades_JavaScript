:root {
  --bg: #f7f1ea;
  --panel: #fffdfa;
  --ink: #372430;
  --ink-soft: #6e5a67;
  --berry: #a4436b;
  --berry-deep: #7d3252;
  --gold: #bd9760;
  --sage: #7c8a6e;
  --line: #e3d6ca;
  --serif: 'Fraunces', serif;
  --sans: 'Work Sans', sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--sans);
  line-height: 1.65;
  position: relative;
}

::selection { background: var(--berry); color: var(--panel); }
a { color: inherit; }
:focus-visible { outline: 2px solid var(--berry); outline-offset: 3px; }

.wrap {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 32px;
  position: relative;
}

/* ---------- Thread line (elemento de assinatura) ---------- */
.thread {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}
.thread svg { position: absolute; top: 0; left: 32px; height: 100%; overflow: visible; }
.thread path {
  fill: none;
  stroke: var(--berry);
  stroke-width: 1.5;
  stroke-dasharray: 6 7;
  opacity: 0.45;
}
.stitch-dot {
  position: absolute;
  width: 9px; height: 9px;
  border-radius: 50%;
  background: var(--berry);
  left: 27px;
  box-shadow: 0 0 0 4px var(--bg);
}

header.hero {
  padding: 88px 0 64px;
  position: relative;
  z-index: 1;
}

.eyebrow {
  font-family: var(--mono);
  font-size: 12.5px;
  letter-spacing: 0.06em;
  color: var(--berry-deep);
  text-transform: uppercase;
  margin-bottom: 18px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.eyebrow::before {
  content: '';
  width: 22px; height: 1px;
  background: var(--berry);
}

h1.name {
  font-family: var(--serif);
  font-optical-sizing: auto;
  font-weight: 600;
  font-size: clamp(42px, 7vw, 64px);
  line-height: 1.05;
  color: var(--ink);
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}
h1.name em {
  font-style: italic;
  color: var(--berry);
  font-weight: 500;
}

.hero-desc {
  font-size: 18px;
  color: var(--ink-soft);
  max-width: 52ch;
  margin-bottom: 30px;
}
.hero-desc strong { color: var(--ink); font-weight: 600; }
.hero-desc code {
  font-family: var(--mono);
  font-size: 15px;
  background: var(--panel);
  border: 1px solid var(--line);
  padding: 1px 7px;
  border-radius: 5px;
  color: var(--berry-deep);
}

.hero-badges { display: flex; gap: 10px; flex-wrap: wrap; }
.hero-badges span {
  font-family: var(--mono);
  font-size: 12.5px;
  color: var(--ink-soft);
  background: var(--panel);
  border: 1px solid var(--line);
  padding: 6px 13px;
  border-radius: 20px;
}

section {
  padding: 64px 0;
  position: relative;
  z-index: 1;
}

.section-label {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
}

h2.section-title {
  font-family: var(--serif);
  font-weight: 600;
  font-size: 30px;
  color: var(--ink);
  margin-bottom: 34px;
}

/* ---------- Skills como amostras de linha ---------- */
.swatch-row {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 14px;
}

.swatch {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 18px 16px;
  text-align: left;
}

.swatch .spool {
  width: 100%;
  height: 8px;
  border-radius: 4px;
  margin-bottom: 14px;
}

.swatch h3 {
  font-family: var(--serif);
  font-size: 16px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 3px;
}

.swatch p {
  font-family: var(--mono);
  font-size: 11.5px;
  color: var(--ink-soft);
}

/* ---------- Projetos ---------- */
.project {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 30px 32px;
  margin-bottom: 20px;
  position: relative;
  transition: box-shadow 0.25s ease, transform 0.25s ease;
}
.project:hover {
  box-shadow: 0 18px 40px -22px rgba(55, 36, 48, 0.35);
  transform: translateY(-3px);
}

.project-num {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--gold);
  margin-bottom: 10px;
  display: block;
}

.project h3 {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 10px;
}

.project p {
  color: var(--ink-soft);
  font-size: 15px;
  margin-bottom: 16px;
  max-width: 56ch;
}

.project-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 6px; }
.project-tags span {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--berry-deep);
  background: rgba(164, 67, 107, 0.08);
  border: 1px solid rgba(164, 67, 107, 0.2);
  padding: 3px 9px;
  border-radius: 5px;
}

.project-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
  font-family: var(--mono);
  font-size: 13px;
  color: var(--berry);
  border-bottom: 1px solid transparent;
  transition: border-color 0.2s ease;
}
.project-link:hover { border-color: var(--berry); }

/* ---------- Contato ---------- */
.contact-card {
  background: linear-gradient(150deg, var(--berry-deep), var(--berry));
  border-radius: 22px;
  padding: 48px 40px;
  color: #fdf3f4;
  text-align: left;
}

.contact-card h2 {
  font-family: var(--serif);
  font-size: 32px;
  font-weight: 600;
  margin-bottom: 14px;
}

.contact-card p {
  color: #f3d9e1;
  max-width: 48ch;
  margin-bottom: 26px;
  font-size: 16px;
}

.contact-links { display: flex; gap: 12px; flex-wrap: wrap; }
.contact-links a {
  font-family: var(--mono);
  font-size: 13.5px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.3);
  padding: 10px 18px;
  border-radius: 20px;
  transition: background 0.2s ease;
}
.contact-links a:hover { background: rgba(255,255,255,0.22); }

footer {
  padding: 40px 0 60px;
  font-family: var(--mono);
  font-size: 12px;
  color: var(--ink-soft);
  position: relative;
  z-index: 1;
}

@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
}

@media (max-width: 640px) {
  .wrap { padding: 0 20px; }
  .thread { display: none; }
  header.hero { padding: 64px 0 48px; }
  section { padding: 48px 0; }
  .contact-card { padding: 36px 26px; }
}
