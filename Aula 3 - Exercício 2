<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aula 3 - Exercício 2</title>
  </head>
  <body>
    <ul id="lista"></ul>

    <button id="btn-fim">Adicionar no fim</button>

    <button id="btn-topo">Adicionar no topo</button>

    <script>
      const lista = document.querySelector("#lista");
const btnFim = document.querySelector("#btn-fim");
const btnTopo = document.querySelector("#btn-topo");

btnFim.addEventListener("click", function () {
  const li = document.createElement("li");
  li.textContent = "Item novo (fim) ";

  const botaoRemover = document.createElement("button");
  botaoRemover.textContent = "remover";
  botaoRemover.addEventListener("click", function () {
    li.remove();
  });

  li.appendChild(botaoRemover);
  lista.appendChild(li);
});

btnTopo.addEventListener("click", function () {
  const li = document.createElement("li");
  li.textContent = "Item novo (topo) ";

  const botaoRemover = document.createElement("button");
  botaoRemover.textContent = "remover";
  botaoRemover.addEventListener("click", function () {
    li.remove();
  });

  li.appendChild(botaoRemover);
  lista.insertBefore(li, lista.firstChild);
});
    </script>
  </body>
</html>
