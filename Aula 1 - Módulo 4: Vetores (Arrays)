<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Módulo 4: Vetores (Arrays)</title>
</head>
<body>
<script>
// Exercício 27: Inverter ordem
const totalNumeros = Number(prompt("Quantos números você deseja informar?"));
const listaOriginal = [];

for (let i = 0; i < totalNumeros; i++) {
  listaOriginal.push(Number(prompt(`Digite o número ${i + 1}:`)));
}

const listaInvertida = [...listaOriginal].reverse();

alert(`Ordem original: ${listaOriginal.join(", ")}\nOrdem inversa: ${listaInvertida.join(", ")}`);


// Exercício 28: Maior e menor do Array
const totalNumerosMaiorMenor = Number(prompt("Quantos números você vai digitar?"));
const listaMaiorMenor = [];

for (let i = 0; i < totalNumerosMaiorMenor; i++) {
  listaMaiorMenor.push(Number(prompt(`Informe o número ${i + 1}:`)));
}

const maior = Math.max(...listaMaiorMenor);
const menor = Math.min(...listaMaiorMenor);

alert(`Maior valor: ${maior}\nMenor valor: ${menor}`);


// Exercício 29: Acima da média
const totalValores = Number(prompt("Quantos valores você deseja calcular?"));
const listaValores = [];

for (let i = 0; i < totalValores; i++) {
  listaValores.push(Number(prompt(`Qual o valor número ${i + 1}?`)));
}

const somaValores = listaValores.reduce((acumulador, valor) => acumulador + valor, 0);
const media = somaValores / listaValores.length;
const acimaDaMedia = listaValores.filter((valor) => valor > media);

alert(`Média: ${media.toFixed(2)}\nValores acima da média: ${acimaDaMedia.join(", ")}`);


// Exercício 30: Soma nas posições pares
const totalNumerosPosicao = Number(prompt("Quantos números você vai informar agora?"));
const listaNumerosPosicao = [];

for (let i = 0; i < totalNumerosPosicao; i++) {
  listaNumerosPosicao.push(Number(prompt(`Valor da posição ${i + 1}:`)));
}

const posicoesPares = listaNumerosPosicao.filter((valor, index) => index % 2 === 0);
const somaPosicoesPares = posicoesPares.reduce((acumulador, valor) => acumulador + valor, 0);

alert(`Soma dos elementos em posições pares (0, 2, 4...): ${somaPosicoesPares}`);


// Exercício 31: Nome mais longo
const totalNomes = Number(prompt("Quantos nomes você vai digitar?"));
const listaNomes = [];

for (let i = 0; i < totalNomes; i++) {
  listaNomes.push(prompt(`Nome número ${i + 1}:`));
}

const nomeMaisLongo = listaNomes.reduce((maior, atual) =>
  atual.length > maior.length ? atual : maior
);

alert(`O nome mais longo é: ${nomeMaisLongo}`);


// Exercício 32: Ordenar valores
const totalNumerosOrdenar = Number(prompt("Quantos números você vai digitar agora?"));
const listaNumerosOrdenar = [];

for (let i = 0; i < totalNumerosOrdenar; i++) {
  listaNumerosOrdenar.push(Number(prompt(`Informe o valor ${i + 1}:`)));
}

listaNumerosOrdenar.sort((a, b) => a - b);

alert(`Números em ordem crescente: ${listaNumerosOrdenar.join(", ")}`);


// Exercício 33: Contar negativos com filter
const totalNumerosNegativos = Number(prompt("Quantos números você vai digitar dessa vez?"));
const listaNumerosNegativos = [];

for (let i = 0; i < totalNumerosNegativos; i++) {
  listaNumerosNegativos.push(Number(prompt(`Valor número ${i + 1}:`)));
}

const quantidadeNegativos = listaNumerosNegativos.filter((num) => num < 0).length;

alert(`Quantidade de números negativos: ${quantidadeNegativos}`);


// Exercício 34: Filtrar ímpares
const valorN = Number(prompt("Digite o valor de N (sequência de 1 até N):"));
const listaSequencia = [];

for (let i = 1; i <= valorN; i++) {
  listaSequencia.push(i);
}

const impares = listaSequencia.filter((num) => num % 2 !== 0);

alert(`Sequência completa: ${listaSequencia.join(", ")}\nApenas ímpares: ${impares.join(", ")}`);
</script>
</body>
</html>