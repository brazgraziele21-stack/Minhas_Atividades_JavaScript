<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aula 3 - Exercício 4</title>
  </head>
  <body>
    <p id="contador">0</p>

    <button id="btn-mais">+1</button>

    <button id="btn-reset">Reiniciar</button>

    <script>
      let contador = document.querySelector("#contador");
const btnMais = document.querySelector("#btn-mais");
const btnReset = document.querySelector("#btn-reset");

let valor = 0;

btnMais.addEventListener("click", function () {
  valor = valor + 1;
  contador.textContent = valor;
});

btnReset.addEventListener("click", function () {
  const novoContador = document.createElement("p");
  novoContador.id = "contador";
  novoContador.textContent = "0";

  contador.parentNode.replaceChild(novoContador, contador);

  contador = novoContador;
  valor = 0;
});
    </script>
  </body>
</html>
