<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <title>Aula 4 - Exercício 3</title>
    <style>
      #caixa {
        background-color: lightblue;
        padding: 20px;
        width: 200px;
      }

      .invisivel {
        display: none;
      }
    </style>
  </head>
  <body>
    <div id="caixa">Texto dentro da caixa</div>
    <button id="btn-esconder">Esconder/Mostrar</button>

    <script>
      const caixa = document.querySelector("#caixa");
      const btnEsconder = document.querySelector("#btn-esconder");

      btnEsconder.addEventListener("click", function () {
        caixa.classList.toggle("invisivel");
      });
    </script>
  </body>
</html>