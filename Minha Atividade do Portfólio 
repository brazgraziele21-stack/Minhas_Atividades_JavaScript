    <div class="voltar-topo" id="botaoVoltarTopo" title="Voltar ao topo">↑</div>

    <script>
        const barraProgresso = document.getElementById("barraProgresso");
const botaoVoltarTopo = document.getElementById("botaoVoltarTopo");

window.addEventListener("scroll", () => {
  const alturaTotal =
    document.documentElement.scrollHeight - window.innerHeight;
  const progresso = (window.scrollY / alturaTotal) * 100;

  barraProgresso.style.width = `${progresso}%`;

  if (window.scrollY > 400) {
    botaoVoltarTopo.classList.add("mostrar");
  } else {
    botaoVoltarTopo.classList.remove("mostrar");
  }
});

botaoVoltarTopo.addEventListener("click", () => {
  document.getElementById("topo-inicio").scrollIntoView({
    behavior: "smooth",
    block: "start",
  });
});
    </script>
