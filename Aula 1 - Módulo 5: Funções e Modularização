<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Módulo 5: Funções e Modularização</title>
</head>
<body>
<script>
// Exercício 35: Função Fatorial Recursiva
function fatorialRecursivo(n) {
  if (n <= 1) return 1;
  return n * fatorialRecursivo(n - 1);
}

const numeroFatorial = Number(prompt("Digite um número para calcular o fatorial:"));
alert(`O fatorial de ${numeroFatorial} é ${fatorialRecursivo(numeroFatorial)}`);


// Exercício 36: MDC (Algoritmo de Euclides)
function calcularMDC(a, b) {
  while (b !== 0) {
    const resto = a % b;
    a = b;
    b = resto;
  }
  return a;
}

const primeiroNumero = Number(prompt("Digite o primeiro número:"));
const segundoNumero = Number(prompt("Digite o segundo número:"));
alert(`O MDC entre ${primeiroNumero} e ${segundoNumero} é ${calcularMDC(primeiroNumero, segundoNumero)}`);


// Exercício 37: Validação de Primo
function primo(n) {
  if (n < 2) return false;
  for (let i = 2; i < n; i++) {
    if (n % i === 0) return false;
  }
  return true;
}

const numeroPrimo = Number(prompt("Digite um número inteiro:"));

if (primo(numeroPrimo)) {
  alert(`${numeroPrimo} é primo? Sim`);
} else {
  alert(`${numeroPrimo} é primo? Não`);
}


// Exercício 38: Calculadora com Arrow Functions
const soma = (a, b) => a + b;
const subtracao = (a, b) => a - b;
const multiplicacao = (a, b) => a * b;

function divisao(a, b) {
  if (b !== 0) {
    return a / b;
  } else {
    return "Erro: divisão por zero";
  }
}

function calculadora(a, b, operacao) {
  let resultado;
  switch (operacao) {
    case "soma": resultado = soma(a, b); break;
    case "subtracao": resultado = subtracao(a, b); break;
    case "multiplicacao": resultado = multiplicacao(a, b); break;
    case "divisao": resultado = divisao(a, b); break;
    default: resultado = "Operação inválida";
  }
  return resultado;
}

const primeiroValor = Number(prompt("Digite o primeiro número:"));
const segundoValor = Number(prompt("Digite o segundo número:"));
const tipoOperacao = prompt("Digite a operação (soma, subtracao, multiplicacao, divisao):");
alert(`Resultado: ${calculadora(primeiroValor, segundoValor, tipoOperacao)}`);


// Exercício 39: Conversão de temperatura Bidirecional
function cParaF(c) { return (c * 9) / 5 + 32; }
function fParaC(f) { return ((f - 32) * 5) / 9; }

const tipoConversao = prompt("Qual conversão deseja fazer?\n1 - Celsius para Fahrenheit\n2 - Fahrenheit para Celsius");

if (tipoConversao === "1") {
  const celsius = Number(prompt("Digite a temperatura em °C:"));
  alert(`${celsius}°C equivalem a ${cParaF(celsius).toFixed(1)}°F`);
} else if (tipoConversao === "2") {
  const fahrenheit = Number(prompt("Digite a temperatura em °F:"));
  alert(`${fahrenheit}°F equivalem a ${fParaC(fahrenheit).toFixed(1)}°C`);
} else {
  alert("Opção inválida.");
}


// Exercício 40: Dia da semana em Array
const dias = ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"];

function obterDiaDaSemana(n) {
  if (n < 1 || n > 7) return "Número inválido";
  return dias[n - 1];
}

const numeroDia = Number(prompt("Digite um número de 1 a 7:"));
alert(`O dia correspondente é: ${obterDiaDaSemana(numeroDia)}`);
</script>
</body>
</html>