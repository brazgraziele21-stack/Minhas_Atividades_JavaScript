<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>7 - Mensagem com tecla ESC</title>
</head>
<body>
    <p id="mensagemEsc"></p>

<script>
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      document.getElementById("mensagemEsc").textContent = "Você apertou ESC!";
    }
  });
</script>
</body>
</html>
