<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2 - Espelho de texto
</title>
</head>
<body>
   <input type="text" id="campoDigitacao" placeholder="Digite algo...">
<p id="espelho"></p>

<script>
  const campo2 = document.getElementById("campoDigitacao");
  const espelho = document.getElementById("espelho");

  campo2.addEventListener("input", () => {
    espelho.textContent = campo2.value;
  });
</script>
</body>
</html>
