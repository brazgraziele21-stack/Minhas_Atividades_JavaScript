<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Grazi Braz| Back-end Developer</title>
  <style>
/* Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg: #0a0a0a;
  --bg-alt: #111318;
  --verde-agua: #00f5d4;
  --roxo-neon: #b100ff;
  --verde-neon: #39ff14;
  --azul-neon: #00d9ff;
  --texto: #e6e6e6;
  --texto-muted: #9a9a9a;
}

body {
  background: var(--bg);
  color: var(--texto);
  font-family: 'Segoe UI', system-ui, sans-serif;
  line-height: 1.6;
}

img {
  max-width: 100%;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
}

.section-title {
  font-size: clamp(1.5rem, 4vw + 1rem, 2.5rem);
  text-align: center;
  margin-bottom: 2rem;
  color: var(--verde-agua);
  text-shadow: 0 0 12px rgba(0, 245, 212, 0.4);
}

/* Header e navegação */
.header {
  padding: 1rem 1.5rem;
  border-bottom: 1px solid #1f1f1f;
  position: sticky;
  top: 0;
  background: rgba(10, 10, 10, 0.9);
  backdrop-filter: blur(6px);
  z-index: 10;
}

.nav {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  align-items: center;
}

.logo {
  font-size: 1.3rem;
  font-weight: bold;
  color: var(--verde-neon);
}

.nav-links {
  display: flex;
  gap: 1.2rem;
  list-style: none;
  flex-wrap: wrap;
  justify-content: center;
}

.nav-links a {
  font-size: 0.9rem;
  color: var(--texto-muted);
  transition: color 0.2s;
}

.nav-links a:hover {
  color: var(--verde-agua);
}

/* Hero */
.hero {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem 1.5rem;
  gap: 1rem;
}

.hero-img {
  width: clamp(120px, 30vw, 180px);
  height: clamp(120px, 30vw, 180px);
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--roxo-neon);
  box-shadow: 0 0 25px rgba(177, 0, 255, 0.5);
}

.hero-title {
  font-size: clamp(2rem, 6vw + 1rem, 3.5rem);
  color: var(--texto);
}

.hero-subtitle {
  font-size: clamp(1rem, 2vw + 0.5rem, 1.3rem);
  color: var(--verde-agua);
}

.btn-primary {
  margin-top: 1rem;
  display: inline-block;
  padding: 0.8rem 2rem;
  border: 2px solid var(--verde-neon);
  color: var(--verde-neon);
  border-radius: 30px;
  font-weight: bold;
  transition: all 0.25s;
}

.btn-primary:hover {
  background: var(--verde-neon);
  color: #000;
  box-shadow: 0 0 20px rgba(57, 255, 20, 0.6);
}

/* Sobre mim */
.sobre {
  padding: 4rem 1.5rem;
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
}

.sobre-texto {
  color: var(--texto-muted);
  font-size: clamp(1rem, 1.5vw + 0.5rem, 1.1rem);
}

/* Skills */
.skills {
  padding: 4rem 1.5rem;
  background: var(--bg-alt);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  max-width: 900px;
  margin: 0 auto;
}

.skill-card {
  background: #16181d;
  border: 1px solid #262a30;
  border-radius: 10px;
  padding: 1.2rem;
  text-align: center;
  font-weight: 600;
  color: var(--azul-neon);
  transition: transform 0.2s, box-shadow 0.2s;
}

.skill-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 0 15px rgba(0, 217, 255, 0.35);
}

/* Portfólio */
.portfolio {
  padding: 4rem 1.5rem;
}

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  max-width: 1000px;
  margin: 0 auto;
}

.project-card {
  background: var(--bg-alt);
  border: 1px solid #262a30;
  border-left: 4px solid var(--roxo-neon);
  border-radius: 10px;
  padding: 1.5rem;
  transition: transform 0.2s;
}

.project-card:hover {
  transform: translateY(-4px);
}

.project-card h3 {
  color: var(--verde-neon);
  margin-bottom: 0.5rem;
}

.project-card p {
  color: var(--texto-muted);
  font-size: 0.95rem;
}

/* Prova social */
.prova-social {
  padding: 4rem 1.5rem;
  background: var(--bg-alt);
}

.numeros-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
}

.numero {
  display: block;
  font-size: clamp(1.8rem, 4vw + 1rem, 2.8rem);
  color: var(--verde-agua);
  font-weight: bold;
}

.numero-label {
  font-size: 0.8rem;
  color: var(--texto-muted);
}

/* Contato */
.contato {
  padding: 4rem 1.5rem;
  text-align: center;
}

.contato-lista {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  align-items: center;
}

.contato-lista a {
  color: var(--verde-agua);
  border-bottom: 1px solid transparent;
  transition: border-color 0.2s;
}

.contato-lista a:hover {
  border-color: var(--verde-agua);
}

/* Footer */
.footer {
  padding: 1.5rem;
  text-align: center;
  color: var(--texto-muted);
  font-size: 0.8rem;
  border-top: 1px solid #1f1f1f;
}

/* Tablet */
@media (min-width: 600px) {
  .nav {
    flex-direction: row;
    justify-content: space-between;
  }

  .skills-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .portfolio-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Desktop */
@media (min-width: 1000px) {
  .skills-grid {
    grid-template-columns: repeat(6, 1fr);
  }

  .portfolio-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

</style>
</head>
<body>

  <!-- Header -->
  <header class="header">
    <nav class="nav">
      <span class="logo">&lt;Grazi Braz/&gt;</span>
      <ul class="nav-links">
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#portfolio">Portfólio</a></li>
        <li><a href="#contato">Contato</a></li>
      </ul>
    </nav>
  </header>

  <!-- Hero -->
  <section class="hero">
    <img src="perfil.jpg" alt="Minha imagem" class="hero-img">
    <h1 class="hero-title">Grazi</h1>
    <p class="hero-subtitle">Back-end Developer | PHP · MySQL · SQL</p>
    <a href="#contato" class="btn-primary">Fale comigo</a>
  </section>

  <!-- Sobre -->
  <section id="sobre" class="sobre">
    <h2 class="section-title">Sobre mim</h2>
    <p class="sobre-texto">
      Estou em transição de carreira para a área de desenvolvimento back-end,
      estudando PHP, MySQL e lógica de programação. Gosto de resolver problemas
      com código limpo e seguro, aplicando boas práticas como prepared statements
      e validação de dados.
    </p>
  </section>

  <!-- Skills -->
  <section id="skills" class="skills">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      <div class="skill-card">PHP</div>
      <div class="skill-card">MySQL</div>
      <div class="skill-card">SQL</div>
      <div class="skill-card">Git</div>
      <div class="skill-card">Lógica de Programação</div>
      <div class="skill-card">Segurança (Prepared Statements)</div>
    </div>
  </section>

  <!-- Portfólio -->
  <section id="portfolio" class="portfolio">
    <h2 class="section-title">Portfólio</h2>
    <div class="portfolio-grid">

      <div class="project-card">
        <h3>Clone YouTube</h3>
        <p>Recriação da página inicial do YouTube usando Flexbox,
          com layout responsivo.</p>
      </div>

      <div class="project-card">
        <h3>Clone Spotify</h3>
        <p>Recriação da página inicial do Spotify usando CSS Grid,
          com layout responsivo.</p>
      </div>

      <div class="project-card">
        <h3>Projeto DVD</h3>
        <p>Descrição em breve.</p>
      </div>

    </div>
  </section>

  <!-- Prova social -->
  <section class="prova-social">
    <h2 class="section-title">Em números</h2>
    <div class="numeros-grid">
      <div class="numero-card">
        <span class="numero">3</span>
        <span class="numero-label">Projetos concluídos</span>
      </div>
      <div class="numero-card">
        <span class="numero">100%</span>
        <span class="numero-label">Mobile-first</span>
      </div>
      <div class="numero-card">
        <span class="numero">+30</span>
        <span class="numero-label">Exercícios práticos</span>
      </div>
    </div>
  </section>

  <!-- Contato -->
  <section id="contato" class="contato">
    <h2 class="section-title">Contato</h2>
    <ul class="contato-lista">
      <li>Email: <a href="mailto:seuemail@exemplo.com">seuemail@exemplo.com</a></li>
      <li>LinkedIn: <a href="#" target="_blank">linkedin.com/in/seu-perfil</a></li>
    </ul>
  </section>

  <footer class="footer">
    <p>&copy; 2026 Grazi — Todos os direitos reservados.</p>
  </footer>

</body>
</html>
