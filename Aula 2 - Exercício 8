<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>8 - Largura da tela</title>
</head>
<body>
    <p>Largura da janela: <span id="larguraTela"></span>px</p>

<script>
  const larguraTela = document.getElementById("larguraTela");

  function atualizarLargura() {
    larguraTela.textContent = window.innerWidth;
  }

  atualizarLargura(); 

  window.addEventListener("resize", atualizarLargura);
</script>
</body>
</html>
