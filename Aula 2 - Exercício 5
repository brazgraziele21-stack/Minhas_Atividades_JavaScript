<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>5 - Contador de letras</title>
</head>
<body>
    <input type="text" id="campoContador" placeholder="Digite algo...">
<p>Letras digitadas: <span id="contadorLetras">0</span></p>

<script>
  const campo5 = document.getElementById("campoContador");
  const contador = document.getElementById("contadorLetras");

  campo5.addEventListener("input", () => {
    contador.textContent = campo5.value.length;
  });
</script>
</body>
</html>
