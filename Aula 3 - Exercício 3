<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aula 3 - Exercício 3</title>
  </head>
  <body>
    <div id="galeria"></div>

    <button id="btn-remover-ultimo">Remover último</button>

    <script>
      const galeria = document.querySelector("#galeria");
const btnRemoverUltimo = document.querySelector("#btn-remover-ultimo");

const imagens = [
  "https://via.placeholder.com/150",
  "https://via.placeholder.com/150",
  "https://via.placeholder.com/150"
];

for (let i = 0; i < imagens.length; i++) {
  const img = document.createElement("img");
  img.setAttribute("src", imagens[i]);
  galeria.appendChild(img);
}

btnRemoverUltimo.addEventListener("click", function () {
  galeria.lastElementChild.remove();
});
    </script>
  </body>
</html>
