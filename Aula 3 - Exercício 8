<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aula 3 - Exercício 8</title>
  </head>
  <body>
    <div id="destaque">
      <p>Conteúdo inicial</p>
    </div>

    <button id="trocar">Trocar destaque</button>

    <script>
      let destaque = document.querySelector("#destaque");
const btnTrocar = document.querySelector("#trocar");

btnTrocar.addEventListener("click", function () {
  const novoDestaque = document.createElement("div");
  novoDestaque.id = "destaque";

  const paragrafo = document.createElement("p");
  paragrafo.textContent = "Novo conteúdo em destaque!";

  novoDestaque.appendChild(paragrafo);

  destaque.parentNode.replaceChild(novoDestaque, destaque);

  destaque = novoDestaque;
});
    </script>
  </body>
</html>
